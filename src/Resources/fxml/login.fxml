<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.Controllers.Login">
   <children>
      <Label alignment="TOP_CENTER" contentDisplay="TOP" layoutX="143.0" layoutY="28.0" text="Hotel Reservation System" textAlignment="CENTER">
         <font>
            <Font name="Bodoni MT Black Italic" size="23.0" />
         </font>
      </Label>
      <Label layoutX="143.0" layoutY="100.0" text="Username:">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <TextField fx:id="usernameField" layoutX="226.0" layoutY="100.0" />
      <Label layoutX="143.0" layoutY="133.0" text="Password:">
         <font>
            <Font size="16.0" />
         </font>
      </Label>
      <PasswordField fx:id="passwordField" layoutX="225.0" layoutY="133.0" />
      <Button fx:id="loginButton" layoutX="330.0" layoutY="174.0" mnemonicParsing="false" onAction="#handleLogin" text="Login" />
      <Button fx:id="registerButton" layoutX="330.0" layoutY="230.0" mnemonicParsing="false" onAction="#handleRegister" text="Register">
         <font>
            <Font size="9.0" />
         </font>
      </Button>
      <Label layoutX="280.0" layoutY="215.0" text="Didnt register already?">
         <font>
            <Font size="10.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
