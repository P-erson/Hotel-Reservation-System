<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.Controllers.RegisterController"
           prefHeight="780.0" prefWidth="1100.0"
           styleClass="main-background"
           stylesheets="@../styles/styles.css">

    <HBox>

        <!-- LEFT PANEL — Branding (same as login) -->
        <VBox prefWidth="420" alignment="CENTER"
              style="-fx-background-color: linear-gradient(to bottom right, #080F1A, #0D1E35, #080F1A);">
            <VBox alignment="CENTER" spacing="16" style="-fx-padding: 60px 50px;">
                <Label text="✦" style="-fx-font-size: 42px; -fx-text-fill: #C5A03C;"/>
                <Label text="AZURE GRAND" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF; -fx-font-family: Georgia;"/>
                <Label text="H  O  T  E  L" style="-fx-font-size: 12px; -fx-text-fill: #C5A03C; -fx-font-family: Georgia; -fx-letter-spacing: 5px;"/>

                <HBox alignment="CENTER" spacing="12" style="-fx-padding: 16px 0;">
                    <Line startX="0" endX="50" stroke="#C5A03C" strokeWidth="0.8" opacity="0.5"/>
                    <Label text="✦" style="-fx-font-size: 9px; -fx-text-fill: #C5A03C;"/>
                    <Line startX="0" endX="50" stroke="#C5A03C" strokeWidth="0.8" opacity="0.5"/>
                </HBox>

                <Label text="Join Our Exclusive Community"
                       style="-fx-font-size: 14px; -fx-text-fill: #8BAABB; -fx-font-family: Georgia; -fx-font-style: italic; -fx-wrap-text: true; -fx-text-alignment: center;"/>

                <VBox spacing="14" style="-fx-padding: 30px 0 0 0;" alignment="CENTER_LEFT">
                    <Label text="🔑  Priority Room Selection" style="-fx-text-fill: #6A8A9A; -fx-font-size: 12px; -fx-font-family: Georgia;"/>
                    <Label text="🎁  Exclusive Member Offers" style="-fx-text-fill: #6A8A9A; -fx-font-size: 12px; -fx-font-family: Georgia;"/>
                    <Label text="💼  Personalized Service" style="-fx-text-fill: #6A8A9A; -fx-font-size: 12px; -fx-font-family: Georgia;"/>
                    <Label text="📱  Easy Reservation Management" style="-fx-text-fill: #6A8A9A; -fx-font-size: 12px; -fx-font-family: Georgia;"/>
                </VBox>
            </VBox>
        </VBox>

        <!-- RIGHT PANEL — Registration Form -->
        <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true"
                    style="-fx-background-color: #0B1520; -fx-background: #0B1520; -fx-border-width: 0;">
            <VBox alignment="CENTER" style="-fx-padding: 40px 60px; -fx-background-color: #0B1520;">

                <VBox styleClass="form-card" spacing="0">

                    <!-- Header -->
                    <VBox spacing="6" alignment="CENTER" style="-fx-padding: 0 0 28px 0;">
                        <Label text="Create Your Account" styleClass="title-label"/>
                        <Label text="Begin your Azure Grand experience today" styleClass="subtitle-label"/>
                    </VBox>

                    <!-- Form Grid -->
                    <GridPane hgap="16" vgap="14">

                        <!-- Row 0: Username + Password -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Username" styleClass="label"/>
                            <TextField fx:id="usernameField" promptText="Choose a username"
                                       styleClass="text-field" prefWidth="190"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Password" styleClass="label"/>
                            <PasswordField fx:id="passwordField" promptText="Min. 8 characters"
                                          styleClass="password-field" prefWidth="190"/>
                        </VBox>

                        <!-- Row 1: Date of Birth + Gender -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Date of Birth" styleClass="label"/>
                            <TextField fx:id="dobField" promptText="YYYY-MM-DD"
                                       styleClass="text-field" prefWidth="190"/>
                        </VBox>

                        <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Gender" styleClass="label"/>
                            <ChoiceBox fx:id="genderChoiceBox" prefWidth="190" prefHeight="42"
                                       styleClass="choice-box"/>
                        </VBox>

                        <!-- Row 2: Address (full width) -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="2"
                              GridPane.columnSpan="2">
                            <Label text="Address" styleClass="label"/>
                            <TextField fx:id="addressField" promptText="Your home address"
                                       styleClass="text-field" prefWidth="396"/>
                        </VBox>

                        <!-- Row 3: Room Preferences (full width) -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="3"
                              GridPane.columnSpan="2">
                            <Label text="Room Preferences" styleClass="label"/>
                            <TextField fx:id="preferencesField" promptText="e.g. Quiet room, high floor, extra pillows..."
                                       styleClass="text-field" prefWidth="396"/>
                        </VBox>

                        <!-- Row 4: Balance -->
                        <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="4"
                              GridPane.columnSpan="2">
                            <Label text="Initial Account Balance ($)" styleClass="label"/>
                            <TextField fx:id="balanceField" promptText="0.00"
                                       styleClass="text-field" prefWidth="396"/>
                        </VBox>

                    </GridPane>

                    <!-- Register Button -->
                    <VBox spacing="14" alignment="CENTER" style="-fx-padding: 28px 0 0 0;">
                        <Button fx:id="registerButton" text="Create My Account"
                                styleClass="button" prefWidth="396" prefHeight="44"
                                onAction="#handleRegister"/>

                        <HBox alignment="CENTER" spacing="8">
                            <Label text="Already have an account?" styleClass="subtitle-label"/>
                            <Button fx:id="loginButton" text="Sign In"
                                    styleClass="secondary-button" onAction="#handleBackToLogin"/>
                        </HBox>
                    </VBox>

                </VBox>
            </VBox>
        </ScrollPane>
    </HBox>
</StackPane>
